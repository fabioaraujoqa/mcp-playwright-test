# ====================================================================
# CONFIGURAÇÕES DO PROJETO - MCP Playwright Test
# ====================================================================
# Este arquivo serve como TEMPLATE. Copie e renomeie para .env.sistema1, 
# .env.sistema2, etc e preencha com seus valores reais.
#
# IMPORTANTE: NÃO COMMITAR com credenciais reais!
# Use este arquivo apenas como referência.
# ====================================================================

# ====================================================================
# SISTEMA 1 - Configurações de Acesso
# ====================================================================

# URL da aplicação
SISTEMA_BASE_URL=https://app.example.com

# Credenciais de teste
SISTEMA_USER=usuario_teste@example.com
SISTEMA_PASSWORD=senha_teste_123

# Timeout padrão (em ms)
SISTEMA_TIMEOUT=5000

# Diretório para salvar evidências/screenshots
SISTEMA_EVIDENCIAS_DIR=tests/evidencias/sistema1


# ====================================================================
# HUB LEITURA - Configurações de Acesso
# ====================================================================

# URL da aplicação (opcional - usa https://hub-de-leitura.vercel.app por padrão)
HUB_BASE_URL=https://hub-de-leitura.vercel.app


# ====================================================================
# SISTEMA 2 - Configurações de Acesso (opcional)
# ====================================================================

# URL da aplicação
SISTEMA2_BASE_URL=https://app2.example.com

# Credenciais de teste
SISTEMA2_USER=usuario_teste@example.com
SISTEMA2_PASSWORD=senha_teste_123

# Timeout padrão (em ms)
SISTEMA2_TIMEOUT=5000

# Diretório para salvar evidências/screenshots
SISTEMA2_EVIDENCIAS_DIR=tests/evidencias/sistema2


# ====================================================================
# CONFIGURAÇÕES GLOBAIS
# ====================================================================

# Ambiente (test, staging, production)
ENV=test

# Tirar screenshots em caso de falha?
SCREENSHOTS_ON_FAILURE=true

# Executar em modo headless (sem interface gráfica)?
# true = headless, false = com navegador visível
HEADED_MODE=false

# Loglevel (debug, info, warning, error)
LOG_LEVEL=info

# Retries em caso de falha
TEST_RETRIES=1

# Timeout global de teste (em ms)
TEST_TIMEOUT=30000

# ====================================================================
# DESENVOLVIDO COM PLAYWRIGHT E MCP
# ====================================================================
# Para mais informações, veja docs/
# ====================================================================
